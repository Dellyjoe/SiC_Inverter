	(text "Line-to-Line"
		(exclude_from_sim no)
		(at 103.886 93.98 90)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "9f8de81b-5e3a-492a-ab0e-e5aa5046402f")
	)
	(text "Per phase (for the full‑bridge output):\n- L1: 1.0 mH, ≥10 A RMS, low loss\n- L2: 1.0 mH, ≥10 A RMS, low loss\n- C: 3.3 µF, ≥250 Vac film\n- R_d: 8.2 Ω in series with C, a few watts\n"
		(exclude_from_sim no)
		(at 134.112 76.454 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "a0cbd602-830c-40a2-ba5d-437fe3a8c852")
	)
	(text "1. A floating 120 Vrms line‑to‑line output is a valid 120 V AC source\nMost people think \"120 V\" means \"120 V from hot to neutral,\" but electrically:\n• 	Appliances only care about the voltage across their two input terminals.\n• 	They do not require one of those terminals to be neutral or earth‑referenced.\n• 	They do not require a grounded conductor to function.\nA floating 2‑wire AC source is completely normal.\n"
		(exclude_from_sim no)
		(at 111.506 111.252 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e6a5ed54-5e97-45b7-bdea-8f0e8ce04715")
	)
