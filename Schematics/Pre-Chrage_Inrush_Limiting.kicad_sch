	(rectangle
		(start 140.462 72.644)
		(end 234.95 118.872)
		(stroke
			(width 0)
			(type default)
		)
		(fill
			(type none)
		)
		(uuid 825ae2e5-88bb-4883-9075-154a68f25708)
	)
	(text "This block limits inrush current into the DC‑link capacitors when the inverter is first connected to the input supply.\n Without pre‑charge, the capacitors appear as a near‑short, causing a large surge current that can stress connectors, \nfuses, MOSFETs, and the EMI filter. The circuit uses a series resistor to control the initial charging current and a \nMOSFET bypass switch to short the resistor once the DC‑link is charged.\n"
		(exclude_from_sim no)
		(at 13.716 25.146 0)
		(effects
			(font
				(size 1.651 1.651)
			)
			(justify left)
		)
		(uuid "113356d1-5eaf-4303-a147-91dbbfa15040")
	)
	(text "Series Per-Charge resistor with MOSFET Bypass"
		(exclude_from_sim no)
		(at 140.462 71.374 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2d6f21c1-c614-4047-bc4e-212a1d52e5c6")
	)
	(text "Pre‑Charge Phase (MOSFET Off)\n- Initial inrush current is limited by:\n"
		(exclude_from_sim no)
		(at 37.592 36.068 0)
		(effects
			(font
				(size 1.651 1.651)
			)
		)
		(uuid "481b167b-922d-49c2-99b6-86ff6a1cdc07")
	)
	(text "This subsheet implements the Pre-Charge circuit for the DC Link Caps"
		(exclude_from_sim no)
		(at 13.462 15.748 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "48f1034c-9576-458a-94f1-e2b30c8c2a8f")
	)
	(text "Run Phase (MOSFET On)\n- Q_PRE is fully enhanced, shorting across R_PRE.\n- The DC‑link sees the full input voltage with minimal conduction loss.\n- R_PRE is removed from the circuit except during the next startup.\n"
		(exclude_from_sim no)
		(at 16.256 67.564 0)
		(effects
			(font
				(size 1.651 1.651)
			)
			(justify left)
		)
		(uuid "73b2340c-c6b7-4173-bab9-5a141a49af7e")
	)
	(text "Because Q_PRE is on the high side, its source rises toward 400 V during pre‑charge. Any future gate‑drive circuit must ensure:\n- The gate voltage is always referenced to the source, not GND.\n- The driver must never force the gate to 0 V (GND‑referenced) while the source is high.\n- A floating or isolated gate driver is required unless you later move the MOSFET to the low side.\nFor now, with the gate as a sheet pin, R5 keeps the MOSFET safely off.\n\nIf you want, we can now write the short \"Design Rationale\" paragraph that sits at the top of the KiCad subsheet, matching the style of your EMI and DC‑link documentation.\n"
		(exclude_from_sim no)
		(at 28.702 128.016 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "f4024612-d01e-46d6-b5ae-725a66a039f4")
	)
